# AI Lorekeeper — Backend Configuration
# Copy this to .env and fill in your values

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lorekeeper
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/lorekeeper

# ─── Supabase Auth ────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ─── Google AI / Gemini API (Gemma 4 inference) ───────────────────────────────
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemma-4-31b-it
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models

UPLOAD_DIR=uploaded_files
MAX_UPLOAD_SIZE_MB=50
MAX_TEXT_CHARS_PER_BATCH=100000
