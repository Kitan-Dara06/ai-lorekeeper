# AI Lorekeeper — Backend Configuration
# Copy this to .env and fill in your values

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lorekeeper
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/lorekeeper

# ─── Supabase Auth ────────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
# Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ─── OpenRouter (Gemma 4 inference) ───────────────────────────────────────────
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Options: google/gemma-4, google/gemini-2.0-flash-exp, etc.
OPENROUTER_MODEL=google/gemma-4
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions

UPLOAD_DIR=uploaded_files
MAX_UPLOAD_SIZE_MB=50
MAX_TEXT_CHARS_PER_BATCH=100000
